ninja_required_version = 1.3
cxx = c++

cflags = -pthread -B /home/ljj/.conda/envs/ugp/compiler_compat -Wl,--sysroot=/ -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -Wstrict-prototypes -fPIC -I/home/ljj/.conda/envs/ugp/lib/python3.8/site-packages/torch/include -I/home/ljj/.conda/envs/ugp/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/ljj/.conda/envs/ugp/lib/python3.8/site-packages/torch/include/TH -I/home/ljj/.conda/envs/ugp/lib/python3.8/site-packages/torch/include/THC -I/usr/local/cuda/include -I/home/ljj/.conda/envs/ugp/include/python3.8 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=ext -D_GLIBCXX_USE_CXX11_ABI=0 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=ext -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++14
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc



